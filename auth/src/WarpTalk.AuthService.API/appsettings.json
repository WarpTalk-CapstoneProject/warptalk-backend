{
  "ConnectionStrings": {
    "AuthDb": "Host=localhost;Port=5432;Database=warptalk;Username=postgres;Password=<SET_VIA_ENV:POSTGRES_PASSWORD>;Search Path=auth,public"
  },
  "Jwt": {
    "Secret": "<SET_VIA_ENV:JWT_SECRET>",
    "Issuer": "WarpTalk.AuthService",
    "Audience": "WarpTalk",
    "AccessTokenExpiryMinutes": 30,
    "RefreshTokenExpiryDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Authentication": {
    "Google": {
      "ClientId": "YOUR_GOOGLE_CLIENT_ID"
    }
  }
}
