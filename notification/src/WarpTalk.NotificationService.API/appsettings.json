{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Secret": "REDACTED_JWT_SECRET",
    "Issuer": "WarpTalk.AuthService",
    "Audience": "WarpTalk"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=warptalk;Username=postgres;Password=<REDACTED_DB_PASSWORD>"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5104",
        "Protocols": "Http1"
      },
      "gRPC": {
        "Url": "http://localhost:50054",
        "Protocols": "Http2"
      }
    }
  }
}
