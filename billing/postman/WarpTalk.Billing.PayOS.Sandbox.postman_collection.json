{
  "info": {
    "_postman_id": "billing-payos-sandbox",
    "name": "WarpTalk Billing - PayOS Sandbox",
    "description": "Test collection for PayOS Sandbox integration with ngrok",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Setup & Config",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Verify service is running"
          }
        },
        {
          "name": "Get Available Plans",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Workspace-Id",
                "value": "{{workspace_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/billing/quota/plans",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "quota", "plans"]
            },
            "description": "Get list of subscription plans"
          }
        }
      ]
    },
    {
      "name": "Payment Flow - Sandbox",
      "item": [
        {
          "name": "1. Create Payment Link (Plan Upgrade)",
          "event": [
            {
              "listen": "tests",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  let response = pm.response.json();",
                  "  pm.environment.set(\"checkout_url\", response.checkoutUrl);",
                  "  pm.environment.set(\"order_code\", response.orderCode);",
                  "  console.log('✅ Payment link created!');",
                  "  console.log('Checkout URL: ' + response.checkoutUrl);",
                  "  console.log('Order Code: ' + response.orderCode);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Workspace-Id",
                "value": "{{workspace_id}}"
              },
              {
                "key": "X-Correlation-Id",
                "value": "{{$randomUUID}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"22222222-2222-2222-2222-222222222222\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/billing/checkout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "checkout"]
            },
            "description": "Create a payment link for plan upgrade"
          }
        },
        {
          "name": "2. Get Payment Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Workspace-Id",
                "value": "{{workspace_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/billing/checkout/{{order_code}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "checkout", "{{order_code}}"]
            },
            "description": "Get payment link details"
          }
        },
        {
          "name": "3. View Payment Result",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "console.log('🔗 Open this URL in browser:');",
                  "console.log(pm.environment.get('checkout_url'));",
                  "console.log('');",
                  "console.log('✏️  Sandbox Test Card:');",
                  "console.log('  Card: 4111111111111111');",
                  "console.log('  Expiry: 12/25');",
                  "console.log('  CVV: 123');",
                  "console.log('  OTP: 123456');",
                  "console.log('');",
                  "console.log('⏳ After payment, wait 5 seconds then run next request...');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Workspace-Id",
                "value": "{{workspace_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/billing/checkout/{{order_code}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "checkout", "{{order_code}}", "status"]
            },
            "description": "Check payment status after completing checkout"
          }
        }
      ]
    },
    {
      "name": "Quota Management",
      "item": [
        {
          "name": "Check Quota",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Workspace-Id",
                "value": "{{workspace_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/billing/quota/check",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "quota", "check"]
            },
            "description": "Check current quota status"
          }
        },
        {
          "name": "Deduct Quota",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Workspace-Id",
                "value": "{{workspace_id}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$randomUUID}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{$randomUUID}}\",\n  \"consumedMinutes\": 15.5,\n  \"source\": \"Weekly Sync Meeting\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/billing/quota/deduct",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "quota", "deduct"]
            },
            "description": "Deduct usage from quota"
          }
        },
        {
          "name": "Refund Quota",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Workspace-Id",
                "value": "{{workspace_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{$randomUUID}}\",\n  \"refundAmount\": 10.5,\n  \"reason\": \"Session was cancelled\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/billing/quota/refund",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "quota", "refund"]
            },
            "description": "Refund quota usage"
          }
        },
        {
          "name": "Get Transaction History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Workspace-Id",
                "value": "{{workspace_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/billing/transactions?page=1&pageSize=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "transactions"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "50"
                }
              ]
            },
            "description": "Get transaction history with pagination"
          }
        },
        {
          "name": "Get Usage Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Workspace-Id",
                "value": "{{workspace_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/billing/quota/usage-logs?page=1&pageSize=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "quota", "usage-logs"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "50"
                }
              ]
            },
            "description": "Get audit logs of quota changes"
          }
        }
      ]
    },
    {
      "name": "Top-up Flow",
      "item": [
        {
          "name": "Create Top-up Payment Link",
          "event": [
            {
              "listen": "tests",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  let response = pm.response.json();",
                  "  pm.environment.set(\"topup_checkout_url\", response.checkoutUrl);",
                  "  pm.environment.set(\"topup_order_code\", response.orderCode);",
                  "  console.log('✅ Top-up payment link created!');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Workspace-Id",
                "value": "{{workspace_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"topUpMinutes\": 100\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/billing/checkout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "checkout"]
            },
            "description": "Create a top-up payment link"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Base URL - Update to ngrok URL when testing with real PayOS"
    },
    {
      "key": "workspace_id",
      "value": "77777777-7777-7777-7777-777777777777",
      "type": "string",
      "description": "Test workspace ID"
    },
    {
      "key": "checkout_url",
      "value": "",
      "type": "string",
      "description": "PayOS checkout URL (auto-populated)"
    },
    {
      "key": "order_code",
      "value": "",
      "type": "string",
      "description": "Order code (auto-populated)"
    },
    {
      "key": "topup_checkout_url",
      "value": "",
      "type": "string",
      "description": "Top-up checkout URL (auto-populated)"
    },
    {
      "key": "topup_order_code",
      "value": "",
      "type": "string",
      "description": "Top-up order code (auto-populated)"
    }
  ]
}
