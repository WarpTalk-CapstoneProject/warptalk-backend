{
  "info": {
    "_postman_id": "8f2c1ff1-f38f-4f43-991a-vnpay-mock",
    "name": "WarpTalk Billing - VNPay Provider Mock",
    "description": "Simulates the VNPay IPN callback shape from the official VNPay sandbox docs. The pre-request script signs vnp_* query parameters with HMAC-SHA512 and appends vnp_SecureHash.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7005"
    },
    {
      "key": "vnp_HashSecret",
      "value": "test-vnpay-hash-secret",
      "type": "secret"
    },
    {
      "key": "vnp_TmnCode",
      "value": "DEMO0001"
    },
    {
      "key": "orderCode",
      "value": "12345"
    },
    {
      "key": "amountVnd",
      "value": "100000"
    }
  ],
  "item": [
    {
      "name": "VNPay IPN - Success Callback",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const hashSecret = pm.collectionVariables.get('vnp_HashSecret') || pm.environment.get('vnp_HashSecret');",
              "const amountVnd = Number(pm.collectionVariables.get('amountVnd') || pm.environment.get('amountVnd'));",
              "const orderCode = pm.collectionVariables.get('orderCode') || pm.environment.get('orderCode');",
              "const pad = value => String(value).padStart(2, '0');",
              "const now = new Date();",
              "const payDate = `${now.getFullYear()}${pad(now.getMonth() + 1)}${pad(now.getDate())}${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}`;",
              "",
              "const params = {",
              "  vnp_Amount: String(amountVnd * 100),",
              "  vnp_BankCode: 'NCB',",
              "  vnp_BankTranNo: 'VNP14226112',",
              "  vnp_CardType: 'ATM',",
              "  vnp_OrderInfo: `WarpTalk_Topup_${orderCode}`,",
              "  vnp_PayDate: payDate,",
              "  vnp_ResponseCode: '00',",
              "  vnp_TmnCode: pm.collectionVariables.get('vnp_TmnCode') || pm.environment.get('vnp_TmnCode'),",
              "  vnp_TransactionNo: '14226112',",
              "  vnp_TransactionStatus: '00',",
              "  vnp_TxnRef: orderCode",
              "};",
              "",
              "const sortedKeys = Object.keys(params).filter(key => params[key]).sort();",
              "const hashData = sortedKeys.map(key => `${encodeURIComponent(key)}=${encodeURIComponent(params[key])}`).join('&');",
              "const secureHash = CryptoJS.HmacSHA512(hashData, hashSecret).toString(CryptoJS.enc.Hex).toLowerCase();",
              "",
              "pm.request.url.query.clear();",
              "sortedKeys.forEach(key => pm.request.url.query.add({ key, value: params[key] }));",
              "pm.request.url.query.add({ key: 'vnp_SecureHash', value: secureHash });",
              "pm.variables.set('vnp_hash_data', hashData);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200 from billing IPN endpoint', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('VNPay IPN response has RspCode and Message', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('RspCode');",
              "  pm.expect(json).to.have.property('Message');",
              "});",
              "",
              "pm.test('RspCode is one of the handled VNPay IPN outcomes', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(['00', '01', '02', '04', '97', '99']).to.include(json.RspCode);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/billing/vnpay/ipn",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "billing",
            "vnpay",
            "ipn"
          ]
        },
        "description": "VNPay IPN mock. Before running, create a pending billing transaction with the same orderCode and amountVnd, then set vnp_HashSecret to match Billing VNPay:HashSecret."
      },
      "response": []
    },
    {
      "name": "VNPay IPN - Invalid Signature",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const amountVnd = Number(pm.collectionVariables.get('amountVnd') || pm.environment.get('amountVnd'));",
              "const orderCode = pm.collectionVariables.get('orderCode') || pm.environment.get('orderCode');",
              "const params = {",
              "  vnp_Amount: String(amountVnd * 100),",
              "  vnp_BankCode: 'NCB',",
              "  vnp_OrderInfo: `WarpTalk_Topup_${orderCode}`,",
              "  vnp_ResponseCode: '00',",
              "  vnp_TmnCode: pm.collectionVariables.get('vnp_TmnCode') || pm.environment.get('vnp_TmnCode'),",
              "  vnp_TransactionNo: '14226112',",
              "  vnp_TransactionStatus: '00',",
              "  vnp_TxnRef: orderCode,",
              "  vnp_SecureHash: 'invalid-signature'",
              "};",
              "pm.request.url.query.clear();",
              "Object.keys(params).sort().forEach(key => pm.request.url.query.add({ key, value: params[key] }));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Invalid signature maps to VNPay RspCode 97', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.RspCode).to.eql('97');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/billing/vnpay/ipn",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "billing",
            "vnpay",
            "ipn"
          ]
        }
      },
      "response": []
    }
  ]
}
