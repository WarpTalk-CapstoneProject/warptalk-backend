{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Security": {
    "RequireAuthentication": true,
    "AllowInsecureWebhookSignatureInDevelopment": false,
    "RequireServiceClientCertificate": false,
    "AllowedServiceClientCertificateThumbprints": []
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Billing": {
    "AutoSeedOnStartup": false
  },
  "AllowedHosts": "*"
}
