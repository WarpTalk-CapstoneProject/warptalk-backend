{
  "ConnectionStrings": {
    "BillingDb": "Host=localhost;Port=5433;Database=warptalk;Username=postgres;Password=<SET_VIA_ENV:BILLING_DB_PASSWORD>;Search Path=billing,public"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Jwt": {
    "SecretKey": "<SET_VIA_ENV:BILLING_JWT_SECRET>",
    "Issuer": "WarpTalk",
    "Audience": "WarpTalk.API",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:5201",
      "http://127.0.0.1:5201"
    ]
  },
  "Auth": {
    "GrpcEndpoint": "http://localhost:50051"
  },
  "README": "This template contains placeholders. Do NOT commit secrets. Set environment variables in your runtime or CI (BILLING_DB_PASSWORD, BILLING_JWT_SECRET)."
}
