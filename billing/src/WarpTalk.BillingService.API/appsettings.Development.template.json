{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "UseInMemoryDatabase": false,
  "ConnectionStrings": {
    "BillingDb": "Host=localhost;Port=55433;Database=warptalk;Username=postgres;Password=__SET_VIA_ENV__;Search Path=billing,public"
  },
  "Security": {
    "RequireAuthentication": false,
    "AllowInsecureWebhookSignatureInDevelopment": true
  },
  "Billing": {
    "AutoSeedOnStartup": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:8080"
    ]
  },
  "PayOS": {
    "ClientId": "__SET_VIA_ENV__",
    "ApiKey": "__SET_VIA_ENV__",
    "ChecksumKey": "__SET_VIA_ENV__",
    "BaseUrl": "https://api-sandbox.payos.vn",
    "IsProduction": false,
    "UseMockService": true
  },
  "Webhook": {
    "ReturnUrl": "http://localhost:3000/checkout/result",
    "CancelUrl": "http://localhost:3000/checkout/cancel"
  }
}
