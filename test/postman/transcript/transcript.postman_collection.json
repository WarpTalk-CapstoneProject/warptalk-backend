    "item":  [
                 {
                     "name":  "03 - Transcript via Gateway",
                     "item":  [
                                  {
                                      "name":  "Start Transcript",
                                      "event":  [
                                                    {
                                                        "listen":  "test",
                                                        "script":  {
                                                                       "exec":  [
                                                                                    "pm.test(\u0027Start transcript returns 200/400/401\u0027, function () {",
                                                                                    "  pm.expect(pm.response.code).to.be.oneOf([200, 400, 401]);",
                                                                                    "});",
                                                                                    "if (pm.response.code === 200) {",
                                                                                    "  var json = pm.response.json();",
                                                                                    "  var id = json.id || json.transcriptId || \u0027\u0027;",
                                                                                    "  if (id) pm.collectionVariables.set(\u0027transcriptId\u0027, id);",
                                                                                    "}"
                                                                                ],
                                                                       "type":  "text/javascript",
                                                                       "packages":  {

                                                                                    },
                                                                       "requests":  {

                                                                                    }
                                                                   }
                                                    }
                                                ],
                                      "request":  {
                                                      "method":  "POST",
                                                      "header":  [
                                                                     {
                                                                         "key":  "Content-Type",
                                                                         "value":  "application/json"
                                                                     },
                                                                     {
                                                                         "key":  "Authorization",
                                                                         "value":  "Bearer {{accessToken}}"
                                                                     }
                                                                 ],
                                                      "body":  {
                                                                   "mode":  "raw",
                                                                   "raw":  "{\n  \"TranslationRoomId\": \"{{translationRoomId}}\",\n  \"SourceLanguage\": \"en-US\"\n}"
                                                               },
                                                      "url":  {
                                                                  "raw":  "{{gatewayBaseUrl}}/api/v1/transcripts",
                                                                  "host":  [
                                                                               "{{gatewayBaseUrl}}"
                                                                           ],
                                                                  "path":  [
                                                                               "api",
                                                                               "v1",
                                                                               "transcripts"
                                                                           ]
                                                              }
                                                  },
                                      "response":  [

                                                   ]
                                  },
