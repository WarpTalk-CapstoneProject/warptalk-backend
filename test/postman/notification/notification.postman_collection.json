                        {
                            "name": "GET Verify Marked As Read",
                            "event": [
                                {
                                    "listen": "test",
                                    "script": {
                                        "exec": [
                                            "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                                            "var jsonData = pm.response.json();",
                                            "var item = jsonData.value.items.find(x => x.id === pm.collectionVariables.get(\"notificationId\"));",
                                            "pm.test(\"Item should be read (or excluded from unread)\", function () {",
                                            "    // Depending on backend, it might exclude read items or just set isRead = true",
                                            "    if (item) {",
                                            "        pm.expect(item.isRead).to.be.true;",
                                            "    }",
                                            "});"
                                        ],
                                        "type": "text/javascript"
                                    }
                                }
                            ],
                            "request": {
                                "method": "GET",
                                "header": [
                                    {
                                        "key": "Authorization",
                                        "value": "Bearer {{accessToken}}"
