                        {
                            "name": "GET Verify All Read",
                            "event": [
                                {
                                    "listen": "test",
                                    "script": {
                                        "exec": [
                                            "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                                            "var jsonData = pm.response.json();",
                                            "pm.test(\"All returned items should be read\", function () {",
                                            "    if(jsonData.value && jsonData.value.items) {",
                                            "        var unread = jsonData.value.items.filter(x => !x.isRead);",
                                            "        pm.expect(unread.length).to.eql(0);",
                                            "    }",
                                            "});"
                                        ],
                                        "type": "text/javascript"
                                    }
                                }
                            ],
                            "request": {
                                "method": "GET",
