                        {
                            "name": "GET Paging Bounds Check",
                            "event": [
                                {
                                    "listen": "test",
                                    "script": {
                                        "exec": [
                                            "pm.test(\"Should not crash, returns 200 or 400\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 400]); });",
                                            "if (pm.response.code === 200) {",
                                            "    var json = pm.response.json();",
                                            "    pm.test(\"Should clamp page size to max 100\", function() { pm.expect(json.value.pageSize).to.be.at.most(100); });",
                                            "}"
                                        ],
                                        "type": "text/javascript"
                                    }
