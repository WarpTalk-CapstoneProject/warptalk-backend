                                    "raw": "{{gatewayBaseUrl}}/api/v1/notifications?page=1&pageSize=50",
                                    "host": [
                                        "{{gatewayBaseUrl}}"
                                    ],
                                    "path": [
                                        "api",
                                        "v1",
                                        "notifications"
                                    ],
                                    "query": [
