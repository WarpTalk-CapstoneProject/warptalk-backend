                    "exec": [
                      "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                      "if (pm.response.code === 200) {",
                      "    var jsonData = pm.response.json();",
                      "    pm.test(\"Response is paginated\", function () {",
                      "        pm.expect(jsonData).to.have.property(\"items\");",
                      "        pm.expect(jsonData).to.have.property(\"totalCount\");",
                      "    });",
                      "    if(jsonData.items.length > 0) {",
                      "        pm.collectionVariables.set(\"notificationId\", jsonData.items[0].id);",
                      "        // XSS Check: Ensure payload does not contain HTML tags",
                      "        jsonData.items.forEach(function(item) {",
                      "            pm.test(\"Payload does not contain HTML\", function () {",
                      "                pm.expect(item.payloadJson).to.not.match(/<[^>]*>/);",
                      "            });",
                      "        });",
                      "    }",
                      "} else {",
                      "    console.log('Response not 200, skipping JSON parse');",
