                                      "event":  [
                                                    {
                                                        "listen":  "test",
                                                        "script":  {
                                                                       "exec":  [
                                                                                    "pm.test(\u0027Create room returns 200/400/401\u0027, function () {",
                                                                                    "  pm.expect(pm.response.code).to.be.oneOf([200, 400, 401]);",
                                                                                    "});",
                                                                                    "if (pm.response.code === 200) {",
                                                                                    "  var json = pm.response.json();",
                                                                                    "  var id = json.id || json.translationRoomId || \u0027\u0027;",
                                                                                    "  if (id) pm.collectionVariables.set(\u0027translationRoomId\u0027, id);",
                                                                                    "}"
                                                                                ],
                                                                       "type":  "text/javascript",
