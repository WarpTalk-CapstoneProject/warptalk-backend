                                                        "listen":  "test",
                                                        "script":  {
                                                                       "type":  "text/javascript",
                                                                       "exec":  [
                                                                                    "pm.test(\u0027Me returns 200 when token valid\u0027, function () {",
                                                                                    "  pm.expect(pm.response.code).to.be.oneOf([200, 401]);",
                                                                                    "});"
                                                                                ]
                                                                   }
                                                    }
                                                ],
                                      "request":  {
                                                      "method":  "GET",
                                                      "header":  [
                                                                     {
